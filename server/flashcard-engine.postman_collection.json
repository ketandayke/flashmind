{
  "info": {
    "name": "Flashcard Engine API",
    "_postman_id": "flashcard-engine-api",
    "description": "Complete API test collection for Flashcard Engine. Run requests in order — Auth first, then Upload, then Decks/Cards/Review.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token",    "value": "", "type": "string" },
    { "key": "deckId",   "value": "", "type": "string" },
    { "key": "cardId",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "0. Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is running', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@flashcard.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register successful', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved:', json.token.slice(0, 20) + '...');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@flashcard.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved from login');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get current user', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user.email).to.eql('test@flashcard.com');",
                  "  pm.expect(json.user.passwordHash).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login - wrong password (should 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@flashcard.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects wrong password', () => {",
                  "  pm.response.to.have.status(401);",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me - no token (should 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects missing token', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "2. Upload",
      "item": [
        {
          "name": "POST /upload (PDF file)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "pdf",
                  "type": "file",
                  "src": "",
                  "description": "Select a PDF file from your computer"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upload accepted (202)', () => {",
                  "  pm.response.to.have.status(202);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.deckId).to.be.a('string');",
                  "  pm.collectionVariables.set('deckId', json.deckId);",
                  "  console.log('deckId saved:', json.deckId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /upload/status/:deckId",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/upload/status/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  console.log('Deck status:', json.status, '| Cards:', json.cardCount);",
                  "  pm.expect(['processing', 'ready', 'failed']).to.include(json.status);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /upload/preview/:deckId (run after status=ready)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/upload/preview/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Preview returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.preview).to.be.an('array');",
                  "  if (json.preview.length > 0) {",
                  "    const c = json.preview[0];",
                  "    pm.expect(c).to.have.property('front');",
                  "    pm.expect(c).to.have.property('back');",
                  "    pm.expect(c).to.have.property('topic');",
                  "    console.log('Sample card front:', c.front);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /upload - no file (should 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/upload",
            "body": { "mode": "formdata", "formdata": [] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects missing file', () => {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "3. Decks",
      "item": [
        {
          "name": "GET /decks (list all)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Decks listed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.decks).to.be.an('array');",
                  "  console.log('Total decks:', json.count);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /decks/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deck fetched', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().deck).to.have.property('title');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /decks/:id (rename)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/decks/{{deckId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Renamed Deck\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deck renamed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().deck.title).to.eql('My Renamed Deck');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /decks/:id/cards",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks/{{deckId}}/cards"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cards listed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.cards).to.be.an('array');",
                  "  console.log('Total cards:', json.count);",
                  "  if (json.cards.length > 0) {",
                  "    pm.collectionVariables.set('cardId', json.cards[0]._id);",
                  "    console.log('cardId saved:', json.cards[0]._id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /decks/:id/cards/due",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks/{{deckId}}/cards/due"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Due cards returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  console.log('Due cards:', pm.response.json().count);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /decks/:id/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks/{{deckId}}/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deck stats returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const s = pm.response.json();",
                  "  console.log(`Total:${s.total} Mastered:${s.mastered} Due:${s.dueToday}`);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "4. Cards",
      "item": [
        {
          "name": "GET /cards/due (all decks)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/due"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Global due cards', () => {",
                  "  pm.response.to.have.status(200);",
                  "  console.log('Global due count:', pm.response.json().count);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /cards/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Card fetched', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const c = pm.response.json().card;",
                  "  console.log('Front:', c.front);",
                  "  console.log('Topic:', c.topic);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /cards (manual create)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/cards",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deckId\": \"{{deckId}}\",\n  \"front\": \"What is Newton's First Law?\",\n  \"back\": \"An object at rest stays at rest, and an object in motion stays in motion, unless acted upon by an external force.\",\n  \"hint\": \"Think about what happens when you slide on ice\",\n  \"topic\": \"Newton's Laws\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Card created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const c = pm.response.json().card;",
                  "  pm.expect(c.front).to.include(\"Newton\");",
                  "  pm.collectionVariables.set('cardId', c._id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /cards/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/cards/{{cardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hint\": \"Updated hint: think about inertia\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Card updated', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().card.hint).to.include('inertia');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /cards/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Card deleted', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "5. Review (SM-2)",
      "item": [
        {
          "name": "GET /review/session/:deckId",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/review/session/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Review session returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  console.log('Cards in session:', json.count);",
                  "  if (json.cards.length > 0) {",
                  "    pm.collectionVariables.set('cardId', json.cards[0]._id);",
                  "    console.log('Using card:', json.cards[0].front.slice(0, 60));",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /review/:cardId — Easy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/review/{{cardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": \"easy\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Easy review applied', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.rating).to.eql('easy');",
                  "  pm.expect(json.interval).to.be.at.least(1);",
                  "  console.log(`Next review in ${json.interval} day(s) | EF: ${json.easeFactor}`);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /review/:cardId — Hard",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/review/{{cardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": \"hard\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Hard review applied', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.rating).to.eql('hard');",
                  "  console.log(`Next review in ${json.interval} day(s) | EF: ${json.easeFactor}`);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /review/:cardId — Again (reset)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/review/{{cardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": \"again\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Again — card reset', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.rating).to.eql('again');",
                  "  pm.expect(json.interval).to.eql(1);",
                  "  pm.expect(json.mastered).to.be.false;",
                  "  console.log('Card reset to interval=1');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /review/:cardId — invalid rating (should 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": "{{baseUrl}}/review/{{cardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": \"excellent\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects invalid rating', () => {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "6. Stats",
      "item": [
        {
          "name": "GET /stats (global)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Global stats returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const s = pm.response.json().stats;",
                  "  console.log(`Decks:${s.totalDecks} Cards:${s.totalCards} Mastered:${s.mastered} Due:${s.dueToday} Mastery:${s.masteryPercent}%`);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /stats/deck/:deckId",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/stats/deck/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deck stats returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  console.log('Deck:', json.title);",
                  "  console.log('Stats:', JSON.stringify(json.stats, null, 2));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "7. Cleanup",
      "item": [
        {
          "name": "DELETE /decks/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/decks/{{deckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deck deleted (with all cards)', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "  pm.collectionVariables.set('deckId', '');",
                  "  pm.collectionVariables.set('cardId', '');",
                  "  console.log('Cleanup complete');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }

  ]
}
